if ASURADA_STATUS_SCREEN_ASURADA

config ZMK_DISPLAY_STATUS_SCREEN_CUSTOM
    select LV_USE_LABEL
    select LV_USE_FLEX
    select LV_USE_ARC
    select LV_USE_BAR
    select LV_USE_CANVAS
    select LV_COLOR_SCREEN_TRANSP

config ZMK_WPM
    default y

# Host CapsLock/NumLock LED state for the keyboard-page lock_status widget.
config ZMK_HID_INDICATORS
    default y

# Small built-in fonts for compact labels (L/R battery, trackball button legend).
config LV_FONT_MONTSERRAT_14
    default y

config LV_FONT_MONTSERRAT_12
    default y

# Bumped 20000 -> 32768: the trackball button legend + pulse objects overran the
# pool, so the display stalled and boot got stuck on the splash.
config LV_Z_MEM_POOL_SIZE
    default 32768

endif
