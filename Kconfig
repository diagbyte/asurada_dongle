# All Asurada options are display-shield specific. Scope the whole block to the
# shield so these symbols (and ASURADA_TOUCH's `select INPUT_CST816S`) never leak
# into unrelated builds sharing the west workspace, e.g. split peripherals.
if SHIELD_ASURADA_ADAPTER

choice ASURADA_STATUS_SCREEN_LAYOUT
    prompt "Status screen layout"
    default ASURADA_STATUS_SCREEN_ASURADA

config ASURADA_STATUS_SCREEN_ASURADA
    bool "Asurada layout"
    help
        Cyber Formula Asurada layout for the 1.28" round GC9A01 display:
        a typing-speed border gauge around the rim with a large centered
        layer name.

config ASURADA_STATUS_SCREEN_CLASSIC
    bool "Classic layout"
    help
        Standard Prospector-derived status screen

config ASURADA_STATUS_SCREEN_RADII
    bool "Radii layout"
    help
        Colorful grid layout with rounded widgets

config ASURADA_STATUS_SCREEN_FIELD
    bool "Field layout"
    help
        Minimal layout with flowing typing activity visualization

config ASURADA_STATUS_SCREEN_OPERATOR
    bool "Operator layout"
    help
        Technical and information dense layout

endchoice

config ASURADA_ROTATE_DISPLAY_180
    bool "Rotate the display 180 degrees"
    default n

config ASURADA_SHOW_MODIFIERS
    bool "Display modifier key indicators (Cmd, Opt, Ctrl, Shift)"
    default y

config ASURADA_SHOW_INACTIVE_MODIFIERS
    bool "Show inactive modifier indicators (dim when not pressed)"
    default y
    depends on ASURADA_SHOW_MODIFIERS
    help
      When enabled, inactive modifiers are shown with a dim color.
      When disabled, inactive modifiers are hidden completely.
      Only affects classic and field layouts.

config ASURADA_MODIFIER_ORDER
    string "Modifier display order"
    default "GACS"
    depends on ASURADA_SHOW_MODIFIERS
    help
      Order of modifier indicators. Use exactly 4 characters:
      G=GUI/Cmd, A=Alt/Opt, C=Control, S=Shift.
      Each character must appear exactly once.

choice ASURADA_MODIFIER_OS
    prompt "Modifier key style"
    default ASURADA_MODIFIER_OS_MAC
    depends on ASURADA_SHOW_MODIFIERS

config ASURADA_MODIFIER_OS_GENERIC
    bool "Generic (CTRL, ALT, GUI, SHFT)"

config ASURADA_MODIFIER_OS_WINDOWS
    bool "Windows"

config ASURADA_MODIFIER_OS_MAC
    bool "Mac"

endchoice

config ASURADA_LAYER_NAME_UPPERCASE
    bool "Display layer names in uppercase"
    default y
    help
      When enabled, layer names will be converted to uppercase for display.

#
# Brightness (no ambient light sensor; controlled by a fixed level + touch swipes)
#
config ASURADA_FIXED_BRIGHTNESS
    int "Display brightness (percent)"
    default 60
    range 1 100
    help
      Initial display backlight brightness. Adjustable at runtime with
      up/down touch swipes when ASURADA_TOUCH is enabled.

config ASURADA_BRIGHTNESS_STEP
    int "Brightness step per swipe (percent)"
    default 10
    range 1 50

#
# CST816S capacitive touch + gestures
#
config ASURADA_TOUCH
    bool "Enable CST816S touch input and gestures"
    default y
    select INPUT
    select INPUT_CST816S
    help
      Enables the CST816S touch controller and gesture handling:
      tap to wake / long-press to sleep, up/down swipe for brightness,
      left/right swipe to navigate the display carousel on the asurada
      layout (BLE profile switching moved to the keyboard's ADJ layer;
      other status screen layouts keep left/right swipe as BLE profile).

config ASURADA_TOUCH_SWIPE_THRESHOLD
    int "Minimum swipe distance in pixels"
    default 30
    range 10 120
    depends on ASURADA_TOUCH

#
# Idle screensaver: the Asurada four eyes
#
config ASURADA_SCREENSAVER
    bool "Show the Asurada four-eyes screensaver when idle"
    default y
    help
      On idle, show the animated Asurada four-eyes face instead of blanking
      the display. The eyes blink and glance around.

config ASURADA_SCREENSAVER_BRIGHTNESS
    int "Screensaver display brightness (percent)"
    default 15
    range 1 100
    depends on ASURADA_SCREENSAVER

config ASURADA_TRACKBALL_LOG
    bool "Log forwarded trackball REL events (Phase-1 bring-up)"
    default n
    help
      Emits an INFO log line per forwarded trackball INPUT_EV_REL event.
      Use to confirm motion reaches the dongle display, then turn off.

config ASURADA_AUTO_PAGE_FOLLOW
    bool "Auto-switch the display page to the active input device"
    depends on ASURADA_STATUS_SCREEN_ASURADA
    default y
    help
      Trackball motion shows the trackball page; typing shows the keyboard
      page. Reliable input-driven navigation that does not depend on the touch
      panel (whose swipe support is flaky on some CST816S modules). Set to n if
      you prefer to stay on a page and navigate only by touch swipe.

config ASURADA_TRACKBALL
    bool "Trackball features (rolling-ball page, pointing-mode text, trackball battery)"
    default y
    help
      Enable the trackball carousel page (the rolling red ball, the SCROLL/SNIPE
      pointing-mode text, and the trackball's battery) plus tapping the forwarded
      pointer input. Turn OFF for a keyboard-only dongle: the carousel becomes two
      pages (keyboard + connections) and no trackball code is built.

config ASURADA_TRACKBALL_SLOT
    int "Split peripheral slot index that is the trackball (its battery shows on the trackball page)"
    default 2
    depends on ASURADA_TRACKBALL
    help
      Which split-central peripheral slot the trackball bonds to (same index as
      the Connections page row). Confirm on hardware; change if the trackball
      battery shows on the wrong slot.

#
# Pointing-mode indicator (trackball page): SCROLL / SNIPE text driven by
# whichever pointing layer is active. The indices are keymap-specific, so
# they're exposed as Kconfig instead of hard-wired to one keymap.
#
config ASURADA_SCROLL_LAYER
    int "Keymap layer index that means SCROLL (shown on the trackball page)"
    default 6

config ASURADA_SCROLL_LAYER2
    int "Second SCROLL layer index (scroll-keep); set = SCROLL layer to disable"
    default 7

config ASURADA_SNIPE_LAYER
    int "Keymap layer index that means SNIPE"
    default 8

#
# Connections page: one row per split peripheral (Left/Right/trackball/...),
# labeled from these strings. Rendered row count follows the actual peripheral
# count at build time; unused labels are simply not shown.
#
config ASURADA_CONN_LABEL_0
    string "Connections page label for split peripheral slot 0"
    default "Left"

config ASURADA_CONN_LABEL_1
    string "Connections page label for split peripheral slot 1"
    default "Right"

config ASURADA_CONN_LABEL_2
    string "Connections page label for split peripheral slot 2"
    default "Trackball"

config ASURADA_CONN_LABEL_3
    string "Connections page label for split peripheral slot 3"
    default "Periph 4"

endif # SHIELD_ASURADA_ADAPTER
